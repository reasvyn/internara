APP_NAME=Internara
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://your-domain.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=internara
DB_USERNAME=internara
DB_PASSWORD=
# For SQLite development:
# DB_CONNECTION=sqlite
# For PostgreSQL:
# DB_CONNECTION=pgsql
# DB_PORT=5432

QUEUE_CONNECTION=sync
# QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis

CACHE_STORE=file
# CACHE_STORE=database
# CACHE_STORE=redis
# CACHE_PREFIX=

SESSION_DRIVER=file
# SESSION_DRIVER=database
# SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local

# Image driver: gd (default, built-in) or imagick (higher quality, requires ext-imagick)
# IMAGE_DRIVER=gd

# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=log
# For production with SMTP:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@domain.com
# MAIL_PASSWORD=your-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@domain.com
# MAIL_FROM_NAME="${APP_NAME}"

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Scheduler access via HTTP (for shared hosting without minute-level cron)
# Generate: php -r "echo bin2hex(random_bytes(16));"
# CRON_SECRET=

# Boost (Laravel development tools)
# BOOST_ENABLED=true
# BOOST_BROWSER_LOGS_WATCHER=true
# BOOST_PHP_EXECUTABLE_PATH=
# BOOST_COMPOSER_EXECUTABLE_PATH=
# BOOST_NPM_EXECUTABLE_PATH=
# BOOST_VENDOR_BIN_EXECUTABLE_PATH=
# BOOST_CURRENT_DIRECTORY_EXECUTABLE_PATH=

# Reverb (WebSocket broadcasting)
# BROADCAST_CONNECTION=reverb
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1
# PUSHER_HOST=localhost
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=

# Livewire file uploads (requires a compatible disk)
# LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local

# Scheduled backups
# BACKUP_ENABLED=false
# BACKUP_FREQUENCY=daily
# BACKUP_SCHEDULE_TIME=02:00
# BACKUP_RETENTION_DAYS=30
# BACKUP_INCLUDE_DATABASE=true
# BACKUP_INCLUDE_STORAGE=true