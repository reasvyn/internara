{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "reasvyn/internara",
    "version": "0.1.0",
    "type": "project",
    "description": "The practical field work management system build with Laravel.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "barryvdh/laravel-dompdf": "^3.1",
        "laravel-lang/lang": "^15.26",
        "laravel/framework": "^12.0",
        "laravel/pulse": "*",
        "laravel/tinker": "^2.10.1",
        "livewire/livewire": "^3.7",
        "livewire/volt": "^1.10",
        "mhmiton/laravel-modules-livewire": "^5.2",
        "nwidart/laravel-modules": "^12.0",
        "php-flasher/flasher-laravel": "^2.4",
        "postare/blade-mdi": "^1.1",
        "robsontenorio/mary": "^2.4",
        "secondnetwork/blade-tabler-icons": "^3.36",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-honeypot": "^4.6",
        "spatie/laravel-medialibrary": "^11.17",
        "spatie/laravel-model-states": "^2.14",
        "spatie/laravel-model-status": "^1.18",
        "spatie/laravel-permission": "^6.24"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^1.8",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.2",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ],
        "exclude-from-classmap": [
            ".temp"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php artisan app:install",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:work --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "dev:ssr": [
            "npm run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --env=ssr\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
        ],
        "test": [
            "@php artisan optimize:clear --ansi",
            "@php artisan app:test"
        ],
        "test:coverage": [
            "@php artisan optimize:clear --ansi",
            "vendor/bin/pest --coverage --min=80"
        ],
        "test:arch": [
            "@php artisan optimize:clear --ansi",
            "vendor/bin/pest tests/Arch --colors=never"
        ],
        "test:feature": [
            "@php artisan optimize:clear --ansi",
            "vendor/bin/pest tests/Feature --colors=never"
        ],
        "test:unit": [
            "@php artisan optimize:clear --ansi",
            "vendor/bin/pest tests/Unit --colors=never"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse --no-progress"
        ],
        "analyse:strict": [
            "vendor/bin/phpstan analyse --level=max --no-progress"
        ],
        "quality": [
            "@lint",
            "@analyse",
            "@test:arch"
        ],
        "quality:full": [
            "@format",
            "@analyse:strict",
            "@test:coverage"
        ],
        "check": [
            "@php artisan about"
        ],
        "lint": [
            "npm run lint",
            "vendor/bin/pint --test"
        ],
        "format": [
            "npm run format",
            "vendor/bin/pint"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "process-timeout": 1800,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
